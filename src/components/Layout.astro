---
import Header from "./Header.astro";
import Footer from "./Footer.astro";
import "../styles/global.css";

const title =
  (Astro.props && Astro.props.title) || "Jake.ac - Jake Jenkins, Web Developer";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <title>{title} | Jake.ac</title>
  </head>
  <body>
    <div class="flex min-h-dvh flex-col">
      <Header view={Astro.props.view} />
      <main class="pt-22 flex-1">
        {
          Astro.props.heroImage && (
            <div class="relative -mt-10 lg:-mt-6 w-full max-h-[400px] h-[400px] overflow-hidden">
              <img
                src={`/images/${Astro.props.heroImage}`}
                alt={
                  Astro.props.heroDescription
                    ? `${Astro.props.heroDescription} image`
                    : ""
                }
                class="w-full h-full object-cover object-center"
              />
            </div>
          )
        }
        <div class="container mx-auto px-10">
          <slot />
        </div>
      </main>
      <Footer />
    </div>
  </body>
</html>
